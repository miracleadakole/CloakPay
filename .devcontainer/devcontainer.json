{
  "name": "CloakPay (Starknet)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "ms-vscode.cpptools",
        "rust-lang.rust-analyzer"
      ]
    }
  },
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash",
    "python.defaultInterpreterPath": "/usr/local/bin/python3"
  },
  "postCreateCommand": "bash /workspace/scripts/setup.sh",
  "forwardPorts": [8000, 5050],
  "remoteUser": "vscode"
}
